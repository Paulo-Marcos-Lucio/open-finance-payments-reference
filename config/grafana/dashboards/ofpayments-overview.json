{
  "title": "OF Payments — Operations Overview",
  "uid": "ofpayments-overview",
  "tags": ["open-finance", "payments", "overview"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "Consents created / sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(ofpayments_audit_events_total{kind=\"CONSENT_CREATED\"}[1m]))" }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": { "unit": "ops", "decimals": 2 }
      }
    },
    {
      "type": "stat",
      "title": "Payments accepted / sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "sum(rate(ofpayments_audit_events_total{kind=\"PAYMENT_ACCEPTED\"}[1m]))" }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": { "unit": "ops", "decimals": 2 }
      }
    },
    {
      "type": "stat",
      "title": "Payments rejected / sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(rate(ofpayments_audit_events_total{kind=\"PAYMENT_REJECTED\"}[1m]))" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 0.1 }
          ]}
        }
      }
    },
    {
      "type": "stat",
      "title": "HTTP p99 latency (PISP endpoints)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{uri=~\"/open-banking/payments/.*\"}[5m])) by (le))"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "decimals": 3 }
      }
    },
    {
      "type": "timeseries",
      "title": "Audit events by kind",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "targets": [
        {
          "expr": "sum by (kind) (rate(ofpayments_audit_events_total[1m]))",
          "legendFormat": "{{kind}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "stacking": { "mode": "normal" } } }
      }
    },
    {
      "type": "timeseries",
      "title": "PISP endpoints — request rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "targets": [
        {
          "expr": "sum by (uri, status) (rate(http_server_requests_seconds_count{uri=~\"/open-banking/payments/.*\"}[1m]))",
          "legendFormat": "{{uri}} ({{status}})"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "type": "timeseries",
      "title": "PISP endpoints — latency p50/p95/p99",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, uri) (rate(http_server_requests_seconds_bucket{uri=~\"/open-banking/payments/.*\"}[5m])))",
          "legendFormat": "p50 {{uri}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket{uri=~\"/open-banking/payments/.*\"}[5m])))",
          "legendFormat": "p95 {{uri}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, uri) (rate(http_server_requests_seconds_bucket{uri=~\"/open-banking/payments/.*\"}[5m])))",
          "legendFormat": "p99 {{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "decimals": 3 }
      }
    }
  ]
}
