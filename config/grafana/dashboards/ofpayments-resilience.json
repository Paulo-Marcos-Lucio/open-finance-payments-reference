{
  "title": "OF Payments — Resilience & JVM",
  "uid": "ofpayments-resilience",
  "tags": ["open-finance", "payments", "resilience", "jvm"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "CB state — holder-consent",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 0 },
      "targets": [
        { "expr": "resilience4j_circuitbreaker_state{name=\"holder-consent\"}", "legendFormat": "{{state}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "type": "stat",
      "title": "CB state — holder-payment",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 0 },
      "targets": [
        { "expr": "resilience4j_circuitbreaker_state{name=\"holder-payment\"}", "legendFormat": "{{state}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "type": "stat",
      "title": "Simulator failures injected / 1m",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 0 },
      "targets": [
        { "expr": "sum(rate(ofpayments_simulator_failures_injected_total[1m]))" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "decimals": 3 } }
    },
    {
      "type": "timeseries",
      "title": "Retry attempts by group",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "targets": [
        {
          "expr": "sum by (name, kind) (rate(resilience4j_retry_calls_total[1m]))",
          "legendFormat": "{{name}} {{kind}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "type": "timeseries",
      "title": "Circuit breaker calls by outcome",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "targets": [
        {
          "expr": "sum by (name, kind) (rate(resilience4j_circuitbreaker_calls_total[1m]))",
          "legendFormat": "{{name}} {{kind}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "type": "timeseries",
      "title": "JVM heap usage",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum by (area) (jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "{{area}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "stacking": { "mode": "normal" } } }
      }
    },
    {
      "type": "timeseries",
      "title": "Threads (live + peak)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 14 },
      "targets": [
        { "expr": "jvm_threads_live_threads", "legendFormat": "live" },
        { "expr": "jvm_threads_peak_threads", "legendFormat": "peak" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ]
}
